    function setDeepLink(reportId, useReplace = false) {
      if (!reportId) return;
      const url = new URL(window.location.href);
      url.searchParams.set("report", reportId);

      if (useReplace) window.history.replaceState({ report: reportId }, "", url.toString());
      else window.history.pushState({ report: reportId }, "", url.toString());
    }

    function getDeepLinkReportId() {
      const url = new URL(window.location.href);
      return url.searchParams.get("report");
    }

    function highlightActiveButton(reportId) {
      if (!reportId) return;

      const buttons = document.querySelectorAll('.report-sidebar button');
      buttons.forEach(btn => btn.classList.remove('active'));

      const btn = document.querySelector(`.report-sidebar button[data-report-id="${reportId}"]`);
      if (btn) {
        btn.classList.add('active');

        // If it's in a submenu, open its parent menu and close others
        const parentMenu = btn.closest('.report-menu');
        if (parentMenu) {
          document.querySelectorAll('.report-menu').forEach(m => {
            if (m !== parentMenu) m.classList.remove('open');
          });
          parentMenu.classList.add('open');
        }
      }
    }

    function loadFromDeepLink() {
      const reportId = getDeepLinkReportId();
      if (!reportId) return false;

      const entry = REPORTS[reportId];
      if (!entry) return false;

      reportLoadReport(entry.url, null, entry.title, reportId);
      return true;
    }

    window.addEventListener("popstate", () => {
      loadFromDeepLink();
    });

    function reportLoadById(reportId, button) {
      const entry = REPORTS[reportId];
      if (!entry) {
        alert("Report not found: " + reportId);
        return;
      }
      reportLoadReport(entry.url, button || null, entry.title, reportId);
    }

    // =========================
    // Loading/error helpers
    // =========================
    function hideLoading() {
      document.getElementById('loadingIndicator').style.display = 'none';
    }

    function reportShowErrorMessage() {
      document.getElementById('reportErrorMessage').style.display = 'block';
    }

    // =========================
    // Sidebar menu accordion (unchanged)
    // =========================
    document.querySelectorAll('.report-menu-header').forEach(header => {
      header.addEventListener('click', () => {
        const menu = header.parentElement;
        const allMenus = document.querySelectorAll('.report-menu');
        allMenus.forEach(m => {
          if (m !== menu) m.classList.remove('open');
        });
        menu.classList.toggle('open');
      });
    });

    // =========================
    // Search (same behavior as yours, but works with data-report-id too)
    // =========================
    document.getElementById('menuSearchInput').addEventListener('input', function () {
      const searchValue = this.value.toLowerCase();
      const buttons = document.querySelectorAll('.report-sidebar button');

      buttons.forEach(btn => {
        const text = btn.textContent.toLowerCase();
        const parentMenu = btn.closest('.report-menu');
        const isMatch = text.includes(searchValue);

        btn.style.display = isMatch ? 'flex' : 'none';

        if (parentMenu && parentMenu.classList.contains('report-menu')) {
          const items = parentMenu.querySelectorAll('.report-menu-items button');
          const anyVisible = [...items].some(i => i.style.display !== 'none');

          parentMenu.style.display = anyVisible ? 'block' : 'none';
          parentMenu.classList.toggle('open', anyVisible);
        }
      });
    });

    // =========================
    // Split Screen Logic
    // =========================
    let splitMode = false;
    let activeFrame = "left";

    const leftBtn = document.getElementById('leftControlBtn');
    const rightBtn = document.getElementById('rightControlBtn');
    const compareBtn = document.getElementById('toggleCompareBtn');
    const resetBtn = document.getElementById('resetSplitBtn');

    compareBtn.addEventListener('click', () => {
      const container = document.getElementById('reportFramesContainer');
      const frame2 = document.getElementById('reportFrame2');
      splitMode = !splitMode;

      if (splitMode) {
        container.classList.add('split');
        frame2.style.display = 'block';
        showControlButtons();
        resetBtn.style.display = 'inline-block';
        alert("✅ Split view enabled.\nClick 🔒 Locked to make that side active.");
      } else {
        container.classList.remove('split');
        frame2.style.display = 'none';
        hideControlButtons();
        resetBtn.style.display = 'none';
      }
    });

    function showControlButtons() {
      leftBtn.style.display = 'inline-block';
      rightBtn.style.display = 'inline-block';
      updateControlButtons();
    }
    function hideControlButtons() {
      leftBtn.style.display = 'none';
      rightBtn.style.display = 'none';
    }

    function updateControlButtons() {
      if (activeFrame === "left") {
        leftBtn.innerText = "🟢 Control";
        leftBtn.classList.remove("locked");
        rightBtn.innerText = "🔒 Locked";
        rightBtn.classList.add("locked");
      } else {
        rightBtn.innerText = "🟢 Control";
        rightBtn.classList.remove("locked");
        leftBtn.innerText = "🔒 Locked";
        leftBtn.classList.add("locked");
      }
    }

    leftBtn.addEventListener('click', () => {
      activeFrame = "left";
      updateControlButtons();
    });
    rightBtn.addEventListener('click', () => {
      activeFrame = "right";
      updateControlButtons();
    });

    // === Reset Split View (keeps the active report)
    resetBtn.addEventListener('click', () => {
      const iframe1 = document.getElementById('reportFrame');
      const iframe2 = document.getElementById('reportFrame2');
      const container = document.getElementById('reportFramesContainer');

      let currentReportUrl = activeFrame === "left" ? iframe1.src : iframe2.src;

      iframe1.src = currentReportUrl;
      iframe2.style.display = "none";
      container.classList.remove("split");

      leftBtn.style.display = "none";
      rightBtn.style.display = "none";
      resetBtn.style.display = "none";
      splitMode = false;
      activeFrame = "left";

      alert("✅ Returned to single view (kept the active report).");
    });

    // =========================
    // Unified report loader (split-aware) + deep link update
    // =========================
    function reportLoadReport(reportUrl, button, title, reportId) {
      const iframe1 = document.getElementById('reportFrame');
      const iframe2 = document.getElementById('reportFrame2');
      const errorMessage = document.getElementById('reportErrorMessage');
      const buttons = document.querySelectorAll('.report-sidebar button');

      document.getElementById('loadingIndicator').style.display = 'block';
      errorMessage.style.display = 'none';

      if (splitMode) {
        if (activeFrame === "left") iframe1.src = reportUrl;
        else iframe2.src = reportUrl;
      } else {
        iframe1.src = reportUrl;
      }

      // Active styling
      if (button) {
        buttons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
      } else if (reportId) {
        highlightActiveButton(reportId);
      }

      if (title) document.title = title;

      // ✅ Update URL
      if (reportId) setDeepLink(reportId);
    }

    // =========================
    // Accessibility for feedback link
    // =========================
    document.getElementById('feedbackLink').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') this.click();
    });

    // =========================
    // Auth + default deep link logic
    // =========================
    window.addEventListener('DOMContentLoaded', () => {
      const lastAuthTime = localStorage.getItem('dashboardAuthTime');
      const now = new Date().getTime();
      const sixtyMinutes = 60 * 60 * 1000;

      if (lastAuthTime && (now - parseInt(lastAuthTime) < sixtyMinutes)) {
        document.getElementById('reportPasswordOverlay').style.display = 'none';
      }

      // ✅ Load deep link if present
      const loaded = loadFromDeepLink();

      // ✅ If no deep link, set default report param (without adding history entry)
      if (!loaded) {
        const defaultReportId = "training";
        setDeepLink(defaultReportId, true);
        highlightActiveButton(defaultReportId);
      }
    });

    // =========================
    // What's New Popup logic (unchanged, but uses deep link loader)
    // =========================
    document.addEventListener('DOMContentLoaded', () => {
      const showUpdatesBtn = document.getElementById('showUpdatesBtn');
      const updatesOverlay = document.getElementById('updatesOverlay');
      const closeUpdatesBtn = document.getElementById('closeUpdatesBtn');

      function showUpdates() {
        updatesOverlay.style.display = 'flex';
        localStorage.setItem('lastUpdatePopupShown', new Date().toDateString());
      }

      function hideUpdates() {
        updatesOverlay.style.display = 'none';
      }

      if (showUpdatesBtn) showUpdatesBtn.addEventListener('click', showUpdates);
      if (closeUpdatesBtn) closeUpdatesBtn.addEventListener('click', hideUpdates);
      if (updatesOverlay) {
        updatesOverlay.addEventListener('click', (e) => {
          if (e.target === updatesOverlay) hideUpdates();
        });
      }

      const lastShown = localStorage.getItem('lastUpdatePopupShown');
      const today = new Date().toDateString();

      const checkLoginInterval = setInterval(() => {
        const passwordOverlay = document.getElementById('reportPasswordOverlay');
        if (passwordOverlay && passwordOverlay.style.display === 'none') {
          clearInterval(checkLoginInterval);
          if (lastShown !== today) {
            setTimeout(showUpdates, 800);
          }
        }
      }, 500);
    });
	  
