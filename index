    .report-sidebar.collapsed {
      width: 0;
      padding: 0;
      overflow: hidden;
    }
    .report-sidebar h2 {
      color: white;
      font-weight: 700;
      margin-bottom: 10px;
      text-align: center;
      font-size: 14px;
    }
