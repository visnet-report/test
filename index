      margin: 0;
      flex-grow: 1;
      text-align: center;
    }
    .toggle-sidebar-btn {
      background: none;
      border: none;
      color: white;
      font-size: 20px;
      cursor: pointer;
      margin-right: 10px;
    }
    .report-content-container {
      display: flex;
      flex: 1;
      overflow: hidden;
    }
    .report-sidebar {
      width: 250px;
      background-color: #220639;
      color: white;
      display: flex;
      flex-direction: column;
      padding: 10px;
