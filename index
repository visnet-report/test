// Chatbot (LLM-assisted) - Frontend
// =========================

// IMPORTANT:
// Your dashboard cannot read data/numbers inside the Looker Studio iframes (cross-origin).
// This chatbot is designed to help users find/open reports and answer "how do I" questions.

const CHAT_API_URL = "http://127.0.0.1:3000/api/dashboard-chat"; 
// If your backend is on another domain, replace with full URL like:
// const CHAT_API_URL = "https://your-backend-domain.com/api/dashboard-chat";

const chatbotFab = document.getElementById("chatbotFab");
const chatbotPanel = document.getElementById("chatbotPanel");
const chatbotCloseBtn = document.getElementById("chatbotCloseBtn");
const chatbotMessages = document.getElementById("chatbotMessages");
const chatbotInput = document.getElementById("chatbotInput");
const chatbotSendBtn = document.getElementById("chatbotSendBtn");

function chatAddMsg(role, text) {
  const wrap = document.createElement("div");
  wrap.className = `chat-msg ${role}`;
  const bubble = document.createElement("div");
  bubble.className = "chat-bubble";
  bubble.textContent = text;
  wrap.appendChild(bubble);
  chatbotMessages.appendChild(wrap);
  chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
}

function chatOpen() {
  chatbotPanel.classList.remove("chatbot-hidden");
  chatbotInput.focus();

  if (chatbotMessages.childElementCount === 0) {
    chatAddMsg("bot", "Hi! Ask me where a report is, e.g.\n- Open AI Traffic\n- Where is SEO Health Score?\n- Show PPC Google\n\nI can also explain Compare mode.");
  }
}
function chatClose() {
  chatbotPanel.classList.add("chatbot-hidden");
}

chatbotFab.addEventListener("click", chatOpen);
chatbotCloseBtn.addEventListener("click", chatClose);

async function chatSend() {
  const q = (chatbotInput.value || "").trim();
  if (!q) return;

  chatAddMsg("user", q);
  chatbotInput.value = "";

  // show temporary "thinking" message
  chatAddMsg("bot", "Thinking...");

  try {
    // Send the report list to the server (so the LLM knows what reports exist)
    const res = await fetch(CHAT_API_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        question: q,
        reports: REPORTS, // you already have REPORTS ✅
        // optional extra context:
        splitMode: splitMode,
        activeFrame: activeFrame
      })
    });

    if (!res.ok) throw new Error("Server returned " + res.status);

    const data = await res.json();

    // Remove the "Thinking..." bubble (last bot msg)
    chatbotMessages.removeChild(chatbotMessages.lastChild);

    if (data.reply) chatAddMsg("bot", data.reply);

    // If LLM says "navigate", load the report
    if (data.intent === "navigate" && data.reportId) {
      // This uses your existing function ✅
      reportLoadById(data.reportId, null);
    }

  } catch (err) {
    chatbotMessages.removeChild(chatbotMessages.lastChild);
    chatAddMsg("bot", "Sorry—chat service is unavailable right now.");
    console.error(err);
  }
}

chatbotSendBtn.addEventListener("click", chatSend);
chatbotInput.addEventListener("keydown", (e) => {
  if (e.key === "Enter") chatSend();
});

	  
